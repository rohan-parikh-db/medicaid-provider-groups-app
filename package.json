{
  "name": "provider-mgmt-medicaid-appkit",
  "version": "1.0.0",
  "description": "Provider Groups (Medicaid Subset) — Databricks App on the AppKit stack",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "NODE_ENV=production node --env-file-if-exists=./.env ./dist/server.js",
    "dev": "NODE_ENV=development tsx watch --tsconfig ./tsconfig.server.json --env-file-if-exists=./.env ./server/server.ts",
    "build:client": "tsc -b tsconfig.client.json && vite build --config client/vite.config.ts",
    "build:server": "tsdown -c tsdown.server.config.ts",
    "build": "npm run build:server && npm run build:client",
    "typecheck": "tsc -p ./tsconfig.server.json --noEmit && tsc -p ./tsconfig.client.json --noEmit",
    "clean": "rm -rf client/dist dist node_modules"
  },
  "dependencies": {
    "@databricks/appkit": "0.23.0",
    "@databricks/sdk-experimental": "0.14.2",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "5.90.16",
    "@tanstack/react-router": "1.145.7",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/express": "5.0.5",
    "@types/node": "24.6.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.0.4",
    "tailwindcss": "4.0.14",
    "tsdown": "0.20.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vite": "7.0.0"
  }
}
